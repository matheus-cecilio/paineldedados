# Core
ENV=development
APP_NAME=Painel Automatizado de Dados
LOG_LEVEL=INFO

# Database (local default uses SQLite)
DATABASE_URL=sqlite:///./app.db
# For Supabase (uncomment and fill):
# DATABASE_URL=postgresql+psycopg2://postgres:<SUPABASE_DB_PASSWORD>@db.<project>.supabase.co:5432/postgres

# Celery (local runs eager, no Redis required)
CELERY_TASK_ALWAYS_EAGER=true
# Redis only needed in prod or when running a real worker
REDIS_URL=redis://localhost:6379/0

# CORS
BACKEND_CORS_ORIGINS=http://localhost:8501,http://localhost:8000

# Supabase Auth (fill in prod)
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
# During local dev, bypass JWT validation
API_AUTH_BYPASS=true

# Optional webhook for import completion notifications (Streamlit or other endpoint)
FRONTEND_WEBHOOK_URL=

# Dashboard config
BACKEND_API_URL=http://localhost:8000
